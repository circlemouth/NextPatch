# NextPatch local server environment template.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTPATCH_RUNTIME_MODE=local-server
NEXTPATCH_DATA_DIR=./data
NEXTPATCH_DB_PATH=./data/nextpatch.sqlite
NEXTPATCH_EXPORT_DIR=./data/exports
NEXTPATCH_LOGIN_PASSWORD=change-me
NEXTPATCH_SESSION_SECRET=replace-with-a-long-random-secret
NEXTPATCH_SESSION_MAX_AGE_SECONDS=604800
NEXTPATCH_COOKIE_SECURE=false
