{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nextpatch.local/schemas/nextpatch.import.v1.schema.json",
  "title": "NextPatch Import v1",
  "type": "object",
  "required": ["schema_version", "source", "summary", "items"],
  "properties": {
    "schema_version": { "const": "nextpatch.import.v1" },
    "source": {
      "type": "object",
      "required": ["tool"],
      "properties": {
        "tool": { "type": "string" },
        "conversation_title": { "type": "string" },
        "captured_at": { "type": "string" },
        "privacy_note": { "type": "string" }
      },
      "additionalProperties": true
    },
    "repository_hint": {
      "type": "object",
      "properties": {
        "owner": { "type": "string" },
        "name": { "type": "string" },
        "branch": { "type": "string" },
        "area": { "type": "string" }
      },
      "additionalProperties": true
    },
    "summary": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "title", "body", "needs_review"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["task", "bug", "idea", "reference_service", "tech_candidate", "future_plan", "note"]
          },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
          "labels": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "string" },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "needs_review": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "unclassified_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "body": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
